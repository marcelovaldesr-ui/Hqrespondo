# ============================================================
# Respondo HQ — Variables de entorno
# Copia este archivo a .env.local y llena los valores.
# En Vercel: Settings → Environment Variables (todas) y redeploy.
# ============================================================

# --- Supabase (Settings → API del proyecto) ---
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Gemini (aistudio.google.com) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Experimental: enriquecer scoring con datos frescos de Google Maps (0 = apagado).
# Gratis hasta 5.000 prompts/mes solo con modelos Gemini 3.x.
GEMINI_MAPS_GROUNDING=0

# --- Google Places API (New) — requiere facturación activa ---
GOOGLE_PLACES_API_KEY=

# --- Acceso al panel (Basic Auth) ---
# Credencial 1 (Marcelo)
HQ_USER=
HQ_PASSWORD=
# Credencial 2 (socio) — opcional; permite registrar quién hizo qué
HQ_USER_2=
HQ_PASSWORD_2=

# --- Token para webhooks de n8n (header x-hq-token) ---
HQ_API_TOKEN=

# --- Link de la demo pública (wa.me) para plantillas de follow-up ---
# Se inserta en los mensajes de prospección; si falta, queda "[link demo]".
NEXT_PUBLIC_DEMO_LINK=

# --- WhatsApp Cloud API (opcional: alertas y brief a tu número) ---
# Sin esto el panel funciona igual; el brief queda en /brief.
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
MI_WHATSAPP=569XXXXXXXX

# ============================================================
# AGENTE DE PROSPECCIÓN (email auto + LinkedIn semi-auto)
# Guía completa: docs/AGENTE_PROSPECCION.md · OAuth Gmail: docs/SETUP_GMAIL_OAUTH.md
# Verifica todo de un vistazo: GET /api/prospeccion/salud?ping=1
# ============================================================

# --- Enriquecimiento (free tier alcanza para las 105 leads) ---
SERPER_API_KEY=            # https://serper.dev  (2.500 búsquedas/mes gratis)
HUNTER_API_KEY=            # https://hunter.io   (25 búsquedas/mes gratis)

# --- Email: cuenta Gmail SECUNDARIA dedicada (no tu correo principal) ---
GMAIL_CLIENT_ID=           # Google Cloud Console → OAuth client (Web)
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=       # se genera 1 vez en OAuth Playground (ver doc)
GMAIL_FROM=               # el email de esa cuenta (ej. hola@respon-do.com)
PROS_FROM_NOMBRE=Marcelo · Respondo

# --- Telegram (alertas de leads calientes) ---
TELEGRAM_BOT_TOKEN=        # @BotFather → /newbot
TELEGRAM_CHAT_ID=          # /api/prospeccion/salud?chatid=1 te lo muestra tras escribirle al bot

# --- Seguridad de los endpoints cron ---
PROS_CRON_SECRET=          # string aleatorio largo (ej. openssl rand -hex 24)

# --- Ajustes opcionales (defaults sensatos si se omiten) ---
PROS_SCORE_MIN=70
PROS_EMAILS_LOTE=6
PROS_ENRIQUECER_LOTE=6
PROS_EMAILS_HORA=30
PROS_LINKEDIN_DIA=20
PROS_MAX_INTENTOS=3
PROS_HORA_INICIO=9
PROS_HORA_FIN=19
