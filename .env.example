# ============================================================
# Respondo HQ — Variables de entorno
# Copia este archivo a .env.local y llena los valores.
# En Vercel: Settings → Environment Variables (todas) y redeploy.
# ============================================================

# --- Supabase (Settings → API del proyecto) ---
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- Gemini (aistudio.google.com) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Experimental: enriquecer scoring con datos frescos de Google Maps (0 = apagado).
# Gratis hasta 5.000 prompts/mes solo con modelos Gemini 3.x.
GEMINI_MAPS_GROUNDING=0

# --- Google Places API (New) — requiere facturación activa ---
GOOGLE_PLACES_API_KEY=

# --- Acceso al panel (Basic Auth) ---
# Credencial 1 (Marcelo)
HQ_USER=
HQ_PASSWORD=
# Credencial 2 (socio) — opcional; permite registrar quién hizo qué
HQ_USER_2=
HQ_PASSWORD_2=

# --- Token para webhooks de n8n (header x-hq-token) ---
HQ_API_TOKEN=

# --- WhatsApp Cloud API (opcional: alertas y brief a tu número) ---
# Sin esto el panel funciona igual; el brief queda en /brief.
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
MI_WHATSAPP=569XXXXXXXX
