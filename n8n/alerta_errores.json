{
  "name": "Respondo HQ — Alerta de errores (Error Workflow global)",
  "nodes": [
    {
      "parameters": {},
      "id": "b1b2c3d4-0001-4000-8000-000000000001",
      "name": "Error Trigger",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [0, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://TU-DOMINIO.vercel.app/api/hooks/bot-events",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-hq-token",
              "value": "REEMPLAZA_CON_TU_HQ_API_TOKEN"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "tipo",
              "value": "error"
            },
            {
              "name": "workflow_id",
              "value": "={{ $json.workflow.id }}"
            },
            {
              "name": "detalle",
              "value": "={{ $json.workflow.name }}: {{ $json.execution?.error?.message ?? 'error sin detalle' }}"
            }
          ]
        },
        "options": {}
      },
      "id": "b1b2c3d4-0002-4000-8000-000000000002",
      "name": "Reportar a Respondo HQ",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [240, 0]
    }
  ],
  "connections": {
    "Error Trigger": {
      "main": [
        [
          {
            "node": "Reportar a Respondo HQ",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {},
  "pinData": {}
}
