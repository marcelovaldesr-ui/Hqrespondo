        "options": {
          "timeout": 10000
        }
      },
      "id": "c1b2c3d4-0001-4000-8000-000000000001",
      "name": "Registrar mensaje en HQ",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [0, 0],
