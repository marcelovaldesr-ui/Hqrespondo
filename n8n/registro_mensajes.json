    {
      "parameters": {
        "method": "POST",
        "url": "https://TU-DOMINIO.vercel.app/api/hooks/bot-events",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-hq-token",
